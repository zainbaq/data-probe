# App Database
POSTGRES_DB=dataprobe
POSTGRES_USER=dataprobe
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://dataprobe:changeme@db:5432/dataprobe

# Redis
REDIS_URL=redis://redis:6379/0

# Clerk (managed auth) — get from https://dashboard.clerk.com
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Encryption key for stored DB credentials (32 bytes hex)
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# CORS
CORS_ORIGINS=http://localhost:3000

# Limits
MAX_UPLOAD_SIZE_MB=250
STATEMENT_TIMEOUT_MS=30000
MAX_PROFILE_ROWS=50000
MAX_TOP_VALUES=20
